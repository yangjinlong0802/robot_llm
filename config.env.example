# ============================================================
# Robot Action Orchestrator - 配置文件模板
# ============================================================
# 使用说明
# ============================================================
#
# 1. 复制此文件为 config.env：
#    cp config.env.example config.env
#
# 2. 根据实际情况修改配置值
#
# 3. 设置运行模式（在 config.env 中设置 RUN_MODE）：
#    RUN_MODE=gui    → 启动 PyQt6 图形界面
#    RUN_MODE=server → 启动 WebSocket 服务
#
#    或者通过命令行环境变量覆盖：
#    RUN_MODE=gui python run.py
#    RUN_MODE=server python run.py --port 9000
#
# 4. 在代码中使用配置：
# ============================================================

# ============================================================
# Robot Action Orchestrator - 统一配置文件
# ============================================================

# ------------------------------------------------------------
# LLM / AI 配置
# ------------------------------------------------------------
# API Key（OpenAI / DeepSeek / 阿里云百炼 等兼容 OpenAI 协议的服务）
OPENAI_API_KEY=

# 模型提供商 (openai / deepseek / dashscope)
MODEL_PROVIDER=dashscope

# API Base URL（可选，留空使用各提供商默认地址）
# OpenAI:    https://api.openai.com/v1
# DeepSeek:  https://api.deepseek.com/v1
# 阿里云百炼：https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称
# OpenAI:    gpt-4o, gpt-4o-mini, gpt-4-turbo
# DeepSeek:  deepseek-reasoner (R1), deepseek-chat (V3)
# 阿里云百炼：qwen-plus, qwen-turbo, qwen-max, qwen-long
OPENAI_MODEL=qwen-turbo

# ------------------------------------------------------------
# 系统配置
# ------------------------------------------------------------
# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 运行模式 (gui / server)
# gui: PyQt6 图形界面模式
# server: WebSocket 服务模式（默认）
RUN_MODE=server

# 模拟模式 (true/false) - 开启后不连接真实硬件
SIMULATION_MODE=false

# 技能库路径
SKILL_LIBRARY_PATH=data/skills/skill_library.json

# ------------------------------------------------------------
# 相机配置
# ------------------------------------------------------------
# 相机管理器类型: realsense（Intel RealSense）/ webcam（本地 USB/内置摄像头）
CAMERA_PROVIDER=realsense

# --- RealSense 配置（CAMERA_PROVIDER=realsense 时生效）---
# 相机序列号，多台用逗号分隔（不填则不启动任何相机，不自动发现）
REALSENSE_DEVICE_SN=153122077516
# 相机名称，与序列号一一对应，多台用逗号分隔（留空则用序列号作为名称）
REALSENSE_DEVICE_NAMES=

# --- OpenCV/Webcam 配置（CAMERA_PROVIDER=webcam 时生效）---
# 摄像头索引，多个用逗号分隔（默认 0）
WEBCAM_DEVICE_INDEXES=0
# 摄像头名称，与索引一一对应，多个用逗号分隔（留空则用 webcam-{index} 作为名称）
WEBCAM_DEVICE_NAMES=

# 相机服务端口（用于从 GUI 获取帧）
VISION_CAMERA_HOST=localhost
VISION_CAMERA_PORT=12345

# YOLO 和 SAM 模型路径
YOLO_MODEL_PATH=models/best.pt
SAM_MODEL_PATH=models/sam2.1_l.pt

# 调试图片保存目录
VISION_DEBUG_SAVE_DIR=pictures

# ------------------------------------------------------------
# 机械臂 RM75 配置
# ------------------------------------------------------------
# Robot1 配置（左手）
ROBOT1_IP=192.168.3.18
ROBOT1_PORT=8080
ROBOT1_INITIAL_POSE=-0.04844,-0.269769,-0.101888,3.109,-0.094,-1.592

# Robot2 配置（右手）
ROBOT2_IP=192.168.3.19
ROBOT2_PORT=8080
ROBOT2_INITIAL_POSE=-0.053437,0.24741,-0.120801,3.114,-0.032,-2.935

# 移动速度配置
MOVE_SPEED=10
MOVE_VELOCITY=10
MOVE_RADIUS=0
MOVE_CONNECT=0
MOVE_BLOCK=1

# 最大尝试次数
MAX_ATTEMPTS=5

# 夹爪配置
GRIPPER_PICK_SPEED=200
GRIPPER_PICK_FORCE=1000
GRIPPER_PICK_TIMEOUT=3
GRIPPER_RELEASE_SPEED=100
GRIPPER_RELEASE_TIMEOUT=3

# ------------------------------------------------------------
# 串口设备配置
# ------------------------------------------------------------
# 身体控制器（ModbusMotor）
BODY_SERIAL_PORT=/dev/body
BODY_BAUDRATE=115200
BODY_SLAVE_ID=1
BODY_TIMEOUT=1

# 快换手（Kuaihuanshou）
KUAIHUANSHOU_SERIAL_PORT=/dev/hand
KUAIHUANSHOU_BAUDRATE=115200
KUAIHUANSHOU_TIMEOUT=3

# ADP 吸液枪
ADP_SERIAL_PORT=/dev/hand
ADP_BAUDRATE=115200
ADP_TIMEOUT=5
ADP_MAX_RETRIES=3

# 继电器控制器
RELAY_SERIAL_PORT=/dev/power
RELAY_BAUDRATE=38400
RELAY_TIMEOUT=1

# # ------------------------------------------------------------
# WebSocket 服务器配置
# ------------------------------------------------------------
# WebSocket 服务端口
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8765

# ------------------------------------------------------------
# MiniCPM 聊天代理配置
# ------------------------------------------------------------
# MiniCPM 网关地址（运行 MiniCPM-o 服务的主机）
MINICPM_GATEWAY_HOST=minicpm.himat.wiat.ac.cn
MINICPM_GATEWAY_PORT=80
# 网关协议：http 或 https（自签名证书时用 https，跳过证书验证）
MINICPM_GATEWAY_SCHEME=http
# 外网反向代理路径前缀（本地直连时留空；走外网时填 /minicpm 等）
MINICPM_GATEWAY_PATH_PREFIX=



# Ask LLM 分类开关（true = 先用 LLM 判断是否为可执行指令）
MINICPM_ASK_ENABLED=true
# Ask LLM 使用的 API Key（留空则复用 OPENAI_API_KEY）
MINICPM_ASK_API_KEY=
# Ask LLM Base URL（留空则复用 OPENAI_BASE_URL）
MINICPM_ASK_BASE_URL=
# Ask LLM 模型名称
MINICPM_ASK_MODEL=qwen-turbo

# ------------------------------------------------------------
# 枪头更换位置配置（末端位姿，单位：米）
# ------------------------------------------------------------
# 枪头 1 位置（第一列）
GUN1_1SHANG=-0.116019,-0.070915,-0.329631,3.139000,-0.004000,-3.004000
GUN1_1XIA=-0.116036,-0.070919,-0.429161,3.139000,-0.005000,-3.004000
GUN1_1ZHONG=-0.116016,-0.070922,-0.403563,3.140000,-0.004000,-3.004000

# 枪头 2 位置（第二列）
GUN2_2SHANG=-0.115142,-0.053850,-0.327644,3.140000,-0.005000,-3.004000
GUN2_2XIA=-0.115132,-0.053854,-0.429501,3.140000,-0.005000,-3.004000
GUN2_2ZHONG=-0.115121,-0.053845,-0.407086,3.140000,-0.004000,-3.004000

# ------------------------------------------------------------
# 其他位置配置
# ------------------------------------------------------------
# 初始位置
INITIAL_POSE=-0.303379,0.274441,-0.075986,-3.081,0.137,-1.828
LEFT_INITIAL_POSE=-0.356,0.309,-0.186,-3.141,0,-1.89
RIGHT_INITIAL_POSE=-0.372,0.221,-0.186,-3.121,0,-1.89

# 放置位置
PLACE_DROP_HEIGHT=0.06
PLACE_ABOVE=0.0637,-0.07351,-0.4182,3.15,0,1.617
PLACE_POS2=0.285488,-0.256408,-0.090654,3.14,0,1.5
