# OpenAI API 配置
OPENAI_API_KEY=sk-145992e50859441bb845ac2b949e722a

# 模型提供商 (openai / deepseek)
MODEL_PROVIDER=deepseek

# 模型名称
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
# DeepSeek: deepseek-reasoner (R1), deepseek-chat (V3)
