# API Key（OpenAI / DeepSeek / 阿里云百炼 等兼容 OpenAI 协议的服务）
OPENAI_API_KEY=sk-6494092d911645d4a8f10bb89e9e9503

# 模型提供商 (openai / deepseek / dashscope)
MODEL_PROVIDER=dashscope

# API Base URL（可选，留空使用各提供商默认地址）
# OpenAI:    https://api.openai.com/v1
# DeepSeek:  https://api.deepseek.com/v1
# 阿里云百炼: https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称
# OpenAI:    gpt-4o, gpt-4o-mini, gpt-4-turbo
# DeepSeek:  deepseek-reasoner (R1), deepseek-chat (V3)
# 阿里云百炼: qwen-plus, qwen-turbo, qwen-max, qwen-long
OPENAI_MODEL=qwen-plus

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 模拟模式 (true/false) - 开启后不连接真实硬件
SIMULATION_MODE=True

# 技能库路径
SKILL_LIBRARY_PATH=data/skills/skill_library.json

# RealSense 相机序列号（留空表示 auto-select，可能受枚举顺序影响）
REALSENSE_DEVICE_SN=153122077516
